# npm config for CloudCLI.
#
# engine-strict=true is the FIRST line of defense against the recurring
# ERR_DLOPEN_FAILED problem on this VPS. The host ships Node 24 at
# /usr/bin/node; this project pins Node 22 (see .env#NODE_BINARY and
# ecosystem.config.cjs#exec_interpreter). Without engine-strict, `npm install`
# with Node 24 silently recompiles better-sqlite3 / node-pty / bcrypt / sharp
# against the Node 24 ABI, and PM2 — running Node 22 — then crashes on dlopen
# with:
#
#   Error: Module did not self-register: '.../better_sqlite3.node'.
#     code: 'ERR_DLOPEN_FAILED'
#
# With engine-strict=true, npm refuses to install if the running node does not
# satisfy the engines field in package.json, so the failure is loud and early
# (during `npm ci` / `npm install`) instead of silent and late (during PM2
# startup).
#
# Update flow on the VPS is: ./scripts/update.sh  (see that file for the full
# explanation of why this still has to be coordinated with PATH).
engine-strict=true
fund=false
audit=false
